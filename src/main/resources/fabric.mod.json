{
	"schemaVersion": 1,
	"id": "spectralesp",
	"version": "${version}",
	"name": "Spectral ESP",
	"description": "An ESP mod that shows entity outlines and hitboxes through walls.",
	"authors": ["godblessmerica"],
	"license": "MIT",
	"environment": "client",
	"entrypoints": {
		"client": [
			"com.spectralesp.client.PlayerESPClient"
		],
		"modmenu": [
			"com.spectralesp.client.ModMenuIntegration"
		]
	},
	"suggests": {
		"modmenu": "*"
	},
	"mixins": [
		{
			"config": "spectral_esp.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~26.1.2",
		"java": ">=25",
		"fabric-api": "*"
	}
}
